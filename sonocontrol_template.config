# SonoControl configuration file
# Format: key = value. Lines beginning with # or ; are ignored.
# This template intentionally contains no max_demand, hold-demand, or dynamic-tau controls.

[device]
device_kind = sonocontrol_fpga

[hyus]
hyus_device_ip = 192.168.0.10
hyus_pulse_len_us = 160
hyus_pulse_period_us = 400
hyus_seq_len_ms = 1
hyus_seq_period_ms = 1000
hyus_run_mode = 0
hyus_pid_var = 1

[ultrasound]
amplitude = 0.5
cfreq_hz = 500000
prf_hz = 1000
duty_cycle = 0.5
wave_shape = sine
duration_ms = 1000
interval_time_s = 5

[experiment]
length_mode = total_duration
use_total_duration = true
total_duration_mins = 60
repeating = 720
hold_after_target_mins = 10
target_tolerance_c = 0.3
sampling_rate_hz = 2

[temperature_safety]
cutoff_temp = 45
cutoff_confirm_samples = 2
cutoff_confirm_min_spacing_ms = 150
min_plausible_temp_c = 10
max_plausible_temp_c = 80
max_temp_rate_c_per_s = 15
temp_channel_fallback = false
temperature_enabled = false
temperature_required = false

[pid_tau_only]
pid_enabled = false
pid_setpoint = 40
pid_amplitude = true
pid_duration = false
pid_duty = false
pid_interval = false
pid_kp = 0.8
pid_ki = 0.05
pid_kd = 0.2
pid_prediction_tau_s = 25
pid_prediction_horizon_s = 0
# Sliding-window width (s) for the least-squares dT/dt fit that smooths the
# temperature slope feeding the predictive model. Default 30, range 5-600.
temp_rate_window_s = 30

[cycling]
use_cycling = false
heating_s = 60
cooling_s = 30
cooling_mode = stop
cooling_hold_temp = 37

[connections]
com3_port = COM3
com11_port = COM11
temp_channel = t1
udp_host = 192.168.0.2
udp_port = 5000
simulate_temp = false
simulate_us = false

[paths]
auto_save_dir =

[long_run_protection]
persistent_com3 = true
communication_retry = true
communication_retry_attempts = 3
communication_retry_initial_backoff_ms = 80
emergency_stop_repeats = 5
watchdog_timeout_ms = 5000

[web_server]
web_server_port = 50896
web_server_snapshot_interval_s = 900
web_server_lan = false
